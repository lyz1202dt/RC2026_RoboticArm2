<mujoco model="arm">
  <compiler angle="radian"/>

  <asset>
    <mesh name="base_link" file="base_link.STL"/>
    <mesh name="link1" file="link1.STL"/>
    <mesh name="link2" file="link2.STL"/>
    <mesh name="link3" file="link3.STL"/>
    <mesh name="link4" file="link4.STL"/>
    <mesh name="link5" file="link5.STL"/>
  </asset>

  <worldbody>
    <geom type="mesh" rgba="1 1 1 1" mesh="base_link"/>
    <body name="link1" pos="0 0 0.032">
      <inertial pos="-0.0270416 -0.0113782 0.0107859" quat="-1.37183e-06 0.707165 0.000233677 0.707049" mass="0.713591" diaginertia="0.0032575 0.00282032 0.000637467"/>
      <joint name="joint1" pos="0 0 0" axis="0 0 -1"/>
      <geom type="mesh" rgba="1 1 1 1" mesh="link1"/>
      <body name="link2" pos="0.3029 -0.0175 0.0075" quat="9.38184e-07 -9.38187e-07 -0.707105 -0.707108">
        <inertial pos="0.136567 0.000474913 0.0163581" quat="0.500091 0.499909 0.500091 0.499909" mass="0.161313" diaginertia="0.00064861 0.000648252 1.8751e-05"/>
        <joint name="joint2" pos="0 0 0" axis="0 0 1"/>
        <geom type="mesh" rgba="1 1 1 1" mesh="link2"/>
        <body name="link3" pos="0.349 0.0025 0.0435" quat="1.32679e-06 0 0 1">
          <inertial pos="0.0915 -0.015 -0.0257239" quat="0.500003 0.500003 0.499997 0.499997" mass="0.0902003" diaginertia="0.000103358 9.68421e-05 1.15901e-05"/>
          <joint name="joint3" pos="0 0 0" axis="0 0 -1"/>
          <geom type="mesh" rgba="1 1 1 1" mesh="link3"/>
          <body name="link4" pos="0.183 -0.03 0" quat="0.707105 0 0 -0.707108">
            <inertial pos="0.0495129 0.0197035 -0.0262229" quat="0.379603 0.413453 0.609869 0.559481" mass="0.0370492" diaginertia="4.42511e-05 2.75163e-05 2.14786e-05"/>
            <joint name="joint4" pos="0 0 0" axis="0 0 1"/>
            <geom type="mesh" rgba="1 1 1 1" mesh="link4"/>
            <geom pos="0.0928 0.027656 -0.026" quat="-3.67321e-06 -1 0 0" type="mesh" rgba="1 1 1 1" mesh="link5"/>
            <site name="ee_site" pos="0 0 0" size="0.01" rgba="1 0 0 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

   <actuator>
    <motor name="motor1" joint="joint1" gear="1" ctrllimited="true" ctrlrange="-20 20"/>
    <motor name="motor2" joint="joint2" gear="1" ctrllimited="true" ctrlrange="-60 60"/>
    <motor name="motor3" joint="joint3" gear="1" ctrllimited="true" ctrlrange="-60 60"/>
    <motor name="motor4" joint="joint4" gear="1" ctrllimited="true" ctrlrange="-20 20"/>
  </actuator>

  <sensor>
    <actuatorpos name="motor1_p" actuator="motor1"/>
    <actuatorpos name="motor2_p" actuator="motor2"/>
    <actuatorpos name="motor3_p" actuator="motor3"/>
    <actuatorpos name="motor4_p" actuator="motor4"/>

    <actuatorvel name="motor1_v" actuator="motor1"/>
    <actuatorvel name="motor2_v" actuator="motor2"/>
    <actuatorvel name="motor3_v" actuator="motor3"/>
    <actuatorvel name="motor4_v" actuator="motor4"/>

    <actuatorfrc name="motor1_f" actuator="motor1" noise="1e-3"/>
    <actuatorfrc name="motor2_f" actuator="motor2" noise="1e-3"/>
    <actuatorfrc name="motor3_f" actuator="motor3" noise="1e-3"/>
    <actuatorfrc name="motor4_f" actuator="motor4" noise="1e-3"/>

    <framepos name="ee_pos" objtype="site" objname="ee_site"/>
    <framequat name="ee_quat" objtype="site" objname="ee_site"/>
  </sensor>
</mujoco>
